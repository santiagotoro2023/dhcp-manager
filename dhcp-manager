  if systemctl is-active --quiet isc-dhcp-server 2>/dev/null; then
    if prompt_yn "Reload DHCP server to apply changes?" Y; then
      systemctl reload-or-restart isc-dhcp-server
      ok "DHCP server reloaded."
    fi
  fi
}

