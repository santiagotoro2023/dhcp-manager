  case "$cmd" in
    install)    cmd_install ;;
    configure)  cmd_configure ;;
    uninstall)  cmd_uninstall ;;

    subnet)
      local sub="${2:-list}"
      case "$sub" in
        add)    cmd_subnet_add ;;
        list)   cmd_subnet_list ;;
        remove) cmd_subnet_remove "${3:-}" ;;
        *)      die "Unknown subnet subcommand: ${sub}" ;;
      esac ;;

    lease)
      local sub="${2:-list}"
      case "$sub" in
        list)   cmd_lease_list ;;
        static)
          local ssub="${3:-list}"
          case "$ssub" in
            add)    cmd_lease_static_add ;;
            list)   cmd_lease_static_list ;;
            remove) cmd_lease_static_remove "${4:-}" ;;
            *)      die "Unknown lease static subcommand: ${ssub}" ;;
          esac ;;
        *)      die "Unknown lease subcommand: ${sub}" ;;
      esac ;;

    option)
      local sub="${2:-list}"
      case "$sub" in
        set)  cmd_option_set ;;
        list) cmd_option_list ;;
        *)    die "Unknown option subcommand: ${sub}" ;;
      esac ;;

    interface)
      local sub="${2:-list}"
      case "$sub" in
        set)  cmd_interface_set "${3:-}" ;;
        list) cmd_interface_list ;;
        *)    die "Unknown interface subcommand: ${sub}" ;;
      esac ;;

    service)  cmd_service "${2:-status}" ;;

    config)
      local sub="${2:-show}"
      case "$sub" in
        show)     cmd_config_show ;;
        edit)     cmd_config_edit ;;
        validate) cmd_config_validate ;;
        backup)   cmd_config_backup ;;
        restore)  cmd_config_restore ;;
        *)        die "Unknown config subcommand: ${sub}" ;;
      esac ;;

    pxe)
      local sub="${2:-configure}"
      [[ "$sub" == "configure" ]] && cmd_pxe_configure || die "Unknown pxe subcommand: ${sub}" ;;

    failover)
      local sub="${2:-configure}"
      [[ "$sub" == "configure" ]] && cmd_failover_configure || die "Unknown failover subcommand: ${sub}" ;;

    pool)
      local sub="${2:-list}"
      case "$sub" in
        add)  cmd_pool_add ;;
        list) cmd_pool_list ;;
        *)    die "Unknown pool subcommand: ${sub}" ;;
      esac ;;

    log)
      local sub="${2:-show}"
      [[ "$sub" == "show" ]] && cmd_log_show || die "Unknown log subcommand: ${sub}" ;;

    --help|-h|help) cmd_help ;;
    --version|-v|version) echo "dhcp-manager v${VERSION}" ;;

    "")  cmd_interactive ;;

    *) err "Unknown command: ${cmd}"; echo ""; cmd_help; exit 1 ;;
  esac
}

main "$@"
