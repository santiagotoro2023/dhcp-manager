cmd_help() {
  cat <<HELP
${BOLD}${CYAN}dhcp-manager${RESET} v${VERSION} — ISC DHCP Server Management Utility

${BOLD}USAGE${RESET}
  dhcp-manager [command] [subcommand] [options]
  Run without arguments for the interactive menu.

${BOLD}COMMANDS${RESET}
  ${CYAN}install${RESET}                         Install isc-dhcp-server
  ${CYAN}configure${RESET}                       Interactive configuration wizard
  ${CYAN}uninstall${RESET}                       Remove isc-dhcp-server

  ${CYAN}subnet add${RESET}                      Add a subnet
  ${CYAN}subnet list${RESET}                     List configured subnets
  ${CYAN}subnet remove${RESET} <network>         Remove a subnet

  ${CYAN}lease list${RESET}                      Show active leases
  ${CYAN}lease static add${RESET}                Add a static lease
  ${CYAN}lease static list${RESET}               List static leases
  ${CYAN}lease static remove${RESET} <mac>       Remove a static lease

  ${CYAN}option set${RESET}                      Set a global DHCP option
  ${CYAN}option list${RESET}                     List global DHCP options

  ${CYAN}interface set${RESET} [iface]            Set listening interface
  ${CYAN}interface list${RESET}                   List network interfaces

  ${CYAN}pxe configure${RESET}                   Configure PXE/TFTP boot
  ${CYAN}failover configure${RESET}              Configure failover peer
  ${CYAN}pool add${RESET}                        Add an address pool to a subnet
  ${CYAN}pool list${RESET}                       List address pools

  ${CYAN}service${RESET} <action>                start|stop|restart|reload|status|enable|disable

  ${CYAN}config show${RESET}                     Print dhcpd.conf (paged)
  ${CYAN}config edit${RESET}                     Open dhcpd.conf in \$EDITOR
  ${CYAN}config validate${RESET}                 Validate dhcpd.conf syntax
  ${CYAN}config backup${RESET}                   Create timestamped backup
  ${CYAN}config restore${RESET}                  Restore from backup

  ${CYAN}log show${RESET}                        Show recent DHCP logs (or follow)

  ${CYAN}--help, -h${RESET}                      Show this help
  ${CYAN}--version, -v${RESET}                   Show version

${BOLD}FILES${RESET}
  Config:   ${DHCPD_CONF}
  Default:  ${DHCPD_DEFAULT}
  Leases:   ${LEASES_FILE}
  Backups:  ${BACKUP_DIR}/

${BOLD}NOTES${RESET}
  * All write operations require root (sudo).
  * The listening interface must have an IPv4 address in the same subnet as
    at least one declared subnet, or dhcpd will refuse to start.
  * Domain name is optional — leave blank to omit it from the config entirely.
