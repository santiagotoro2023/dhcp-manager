#!/usr/bin/env bash
# =============================================================================
# dhcp-manager — ISC DHCP Server Installation & Configuration Utility
# =============================================================================
# Usage:
#   dhcp-manager                         Interactive menu
#   dhcp-manager install                 Install isc-dhcp-server
#   dhcp-manager configure               Run configuration wizard
#   dhcp-manager subnet add              Add a subnet
#   dhcp-manager subnet list             List configured subnets
#   dhcp-manager subnet remove <net>     Remove a subnet
#   dhcp-manager lease list              Show active leases
#   dhcp-manager lease static add        Add a static lease
#   dhcp-manager lease static list       List static leases
#   dhcp-manager lease static remove <mac>
#   dhcp-manager option set              Set global DHCP options
#   dhcp-manager option list             Show global options
#   dhcp-manager service <action>        start|stop|restart|reload|status|enable|disable
#   dhcp-manager config show             Print dhcpd.conf
#   dhcp-manager config edit             Open dhcpd.conf in $EDITOR
#   dhcp-manager config validate         Validate dhcpd.conf syntax
#   dhcp-manager config backup           Backup dhcpd.conf
#   dhcp-manager config restore          Restore from backup
#   dhcp-manager interface set [iface]   Set listening interface
#   dhcp-manager interface list          List available interfaces
#   dhcp-manager pxe configure           Configure PXE boot
#   dhcp-manager failover configure      Configure failover peer
#   dhcp-manager pool add                Add address pool to subnet
#   dhcp-manager pool list               List all pools
#   dhcp-manager log show                Show DHCP server logs
#   dhcp-manager uninstall               Remove isc-dhcp-server
#   dhcp-manager --help                  Show this help
#   dhcp-manager --version               Show version
# =============================================================================

set -euo pipefail

# ── Constants ─────────────────────────────────────────────────────────────────
readonly VERSION="1.6.0"
readonly DHCPD_CONF="/etc/dhcp/dhcpd.conf"
readonly DHCPD_DEFAULT="/etc/default/isc-dhcp-server"
readonly LEASES_FILE="/var/lib/dhcp/dhcpd.leases"
readonly BACKUP_DIR="/etc/dhcp/backups"

# ── Colours ───────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  RED='\033[0;31m'    YELLOW='\033[1;33m'  GREEN='\033[0;32m'
  CYAN='\033[0;36m'   BLUE='\033[0;34m'    MAGENTA='\033[0;35m'
  BOLD='\033[1m'      DIM='\033[2m'        RESET='\033[0m'
else
  RED='' YELLOW='' GREEN='' CYAN='' BLUE='' MAGENTA=''
  BOLD='' DIM='' RESET=''
fi

# ── Trap: clean exit on Ctrl+C ────────────────────────────────────────────────
trap 'echo -e "\n${DIM}Interrupted.${RESET}"; exit 130' INT TERM

# ── Logging helpers ───────────────────────────────────────────────────────────
info()    { echo -e "${CYAN}[INFO]${RESET}  $*"; }
ok()      { echo -e "${GREEN}[ OK ]${RESET}  $*"; }
warn()    { echo -e "${YELLOW}[WARN]${RESET}  $*" >&2; }
err()     { echo -e "${RED}[ERR ]${RESET}  $*" >&2; }
die()     { err "$*"; exit 1; }
header()  { echo -e "\n${BOLD}${CYAN}━━━  $*  ━━━${RESET}\n"; }
section() { echo -e "\n${BOLD}▸ $*${RESET}"; }
divider() { echo -e "${DIM}────────────────────────────────────────────────────${RESET}"; }
hint()    { echo -e "  ${DIM}→ $*${RESET}"; }
blank()   { echo ""; }

# Pause after displaying read-only output in interactive mode
_pause() {
  [[ -t 0 ]] || return 0
  echo ""
  echo -ne "${DIM}Press Enter to continue...${RESET}"
  read -r _
}

# ── Privilege check ───────────────────────────────────────────────────────────
require_root() {
  [[ $EUID -eq 0 ]] || die "This command requires root. Try: sudo dhcp-manager $*"
}

# ── Dependency check ──────────────────────────────────────────────────────────
require_dhcpd() {
  command -v dhcpd &>/dev/null || die "isc-dhcp-server is not installed. Run: dhcp-manager install"
  [[ -f "$DHCPD_CONF" ]] || die "Config not found: ${DHCPD_CONF}. Run: dhcp-manager configure"
}

# ── Prompt helpers ────────────────────────────────────────────────────────────

# prompt <varname> <question> [default]
# Required — loops until non-empty (or default used).
prompt() {
  local varname="$1" question="$2" default="${3:-}"
  local disp_def=""
  [[ -n "$default" ]] && disp_def=" ${DIM}[${default}]${RESET}"
  while true; do
    echo -ne "  ${BOLD}${question}${RESET}${disp_def}: "
    read -r "$varname"
    local val="${!varname}"
    if [[ -z "$val" && -n "$default" ]]; then
      printf -v "$varname" '%s' "$default"; return 0
    elif [[ -n "$val" ]]; then
      return 0
    fi
    warn "A value is required."
  done
}

# prompt_opt <varname> <question> [default]
# Optional — blank input accepted; sets default if provided.
prompt_opt() {
  local varname="$1" question="$2" default="${3:-}"
  local disp_def=""
  [[ -n "$default" ]] && disp_def=" ${DIM}[${default}]${RESET}"
  echo -ne "  ${BOLD}${question}${RESET}${disp_def}: "
  read -r "$varname"
  local val="${!varname}"
  if [[ -z "$val" && -n "$default" ]]; then
    printf -v "$varname" '%s' "$default"
  fi
}

# prompt_yn <question> [default Y|N]  → returns 0 for yes, 1 for no
prompt_yn() {
  local question="$1" default="${2:-Y}"
  local opts="Y/n"; [[ "${default^^}" == "N" ]] && opts="y/N"
  while true; do
    echo -ne "  ${BOLD}${question}${RESET} [${opts}]: "
    read -r _yn
    _yn="${_yn:-$default}"
    case "${_yn^^}" in
      Y|YES) return 0 ;;
      N|NO)  return 1 ;;
      *)     warn "Please answer y or n." ;;
    esac
  done
}

# prompt_select <varname> <question> <opt1> <opt2> ...
prompt_select() {
  local varname="$1" question="$2"; shift 2
  local opts=("$@")
  section "$question"
  local i=1
  for opt in "${opts[@]}"; do
    echo -e "  ${CYAN}${i})${RESET} ${opt}"
    (( i++ ))
  done
  blank
  while true; do
    echo -ne "  ${BOLD}Choice${RESET} [1-${#opts[@]}]: "
    read -r _sel
    if [[ "$_sel" =~ ^[0-9]+$ ]] && (( _sel >= 1 && _sel <= ${#opts[@]} )); then
      printf -v "$varname" '%s' "${opts[$((_sel-1))]}"; return 0
    fi
    warn "Enter a number between 1 and ${#opts[@]}."
  done
}

# ── Validation helpers ────────────────────────────────────────────────────────
is_valid_ip() {
  local ip="$1"
  [[ "$ip" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}$ ]] || return 1
  local IFS='.'; read -ra parts <<< "$ip"
  for p in "${parts[@]}"; do (( p <= 255 )) || return 1; done
}

is_valid_cidr() {
  [[ "$1" =~ ^([0-9]{1,3}\.){3}[0-9]{1,3}/([0-9]|[12][0-9]|3[0-2])$ ]] || return 1
  is_valid_ip "${1%/*}"
}

is_valid_mac() {
  [[ "$1" =~ ^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$ ]]
}

is_valid_seconds() {
  [[ "$1" =~ ^[0-9]+$ ]] && (( $1 > 0 && $1 <= 2147483647 ))
}

cidr_to_netmask() {
  local prefix="$1"
  local full=$(( prefix / 8 )) rem=$(( prefix % 8 )) octets=()
  for (( i=0; i<4; i++ )); do
    if   (( i <  full )); then octets+=(255)
    elif (( i == full )); then octets+=( $(( 256 - (1 << (8 - rem)) )) )
    else octets+=(0)
    fi
  done
  echo "${octets[0]}.${octets[1]}.${octets[2]}.${octets[3]}"
}

network_address() {
  local IFS='.'; read -ra ip <<< "$1"; read -ra nm <<< "$2"
  echo "$(( ip[0] & nm[0] )).$(( ip[1] & nm[1] )).$(( ip[2] & nm[2] )).$(( ip[3] & nm[3] ))"
}

broadcast_address() {
  local IFS='.'; read -ra ip <<< "$1"; read -ra nm <<< "$2"
  echo "$(( ip[0] | (255^nm[0]) )).$(( ip[1] | (255^nm[1]) )).$(( ip[2] | (255^nm[2]) )).$(( ip[3] | (255^nm[3]) ))"
}

# ── Backup ────────────────────────────────────────────────────────────────────
backup_conf() {
  [[ -f "$DHCPD_CONF" ]] || return 0
  mkdir -p "$BACKUP_DIR"
  local ts; ts=$(date +%Y%m%d_%H%M%S)
  local dest="${BACKUP_DIR}/dhcpd.conf.${ts}"
  cp "$DHCPD_CONF" "$dest"
  info "Backup saved: ${dest}"
}

# ── Status helpers ────────────────────────────────────────────────────────────
_service_state() {
  if ! command -v dhcpd &>/dev/null; then echo "not installed"; return; fi
  if systemctl is-active --quiet isc-dhcp-server 2>/dev/null; then
    echo "running"
  elif systemctl is-failed --quiet isc-dhcp-server 2>/dev/null; then
    echo "failed"
  else
    echo "stopped"
  fi
}

_active_interface() {
  [[ -f "$DHCPD_DEFAULT" ]] || { echo "none"; return; }
  grep -oP 'INTERFACESv4="\K[^"]+' "$DHCPD_DEFAULT" 2>/dev/null || echo "none"
}

_subnet_count() {
  [[ -f "$DHCPD_CONF" ]] || { echo "0"; return; }
  grep -cP '^subnet\s' "$DHCPD_CONF" 2>/dev/null || echo "0"
}

_active_lease_count() {
  [[ -f "$LEASES_FILE" ]] || { echo "0"; return; }
  python3 -c "
import re, sys
with open('$LEASES_FILE') as f: c = f.read()
active = [m for m in re.finditer(r'lease\s+[\d.]+\s*\{(.*?)\}', c, re.DOTALL)
          if re.search(r'binding state active;', m.group(1))]
print(len(active))
" 2>/dev/null || echo "?"
}

# ── Config file writer ────────────────────────────────────────────────────────
write_conf_header() {
  cat > "$DHCPD_CONF" <<EOF
# =============================================================================
# dhcpd.conf — Managed by dhcp-manager v${VERSION}
# Generated: $(date)
# =============================================================================

EOF
}

# ── INSTALL ───────────────────────────────────────────────────────────────────
cmd_install() {
  require_root
  header "Install ISC DHCP Server"

  if command -v dhcpd &>/dev/null; then
    local installed_ver; installed_ver=$(dhcpd --version 2>&1 | head -1 || echo "unknown")
    ok "isc-dhcp-server is already installed (${installed_ver})."
    prompt_yn "Run the configuration wizard now?" Y && cmd_configure
    return 0
  fi

  info "Updating package lists..."
  apt-get update -qq || die "apt-get update failed. Check your network connection."
  info "Installing isc-dhcp-server..."
  DEBIAN_FRONTEND=noninteractive apt-get install -y isc-dhcp-server \
    || die "Installation failed. Check apt output above."
  ok "isc-dhcp-server installed successfully."

  # Prevent post-install auto-start failure on empty config
  systemctl stop    isc-dhcp-server 2>/dev/null || true
  systemctl disable isc-dhcp-server 2>/dev/null || true

  blank
  prompt_yn "Run the initial configuration wizard now?" Y \
    && cmd_configure \
    || info "Run 'dhcp-manager configure' whenever you're ready."
}

# ── CONFIGURE WIZARD ──────────────────────────────────────────────────────────
cmd_configure() {
  require_root
  require_dhcpd
  header "DHCP Configuration Wizard"
  hint "Global settings (DNS, lease times, domain) can be changed later"
  hint "from the main menu → Global options (5)."
  blank

  backup_conf

  # ── Step 1: Interface ──────────────────────────────────────────────────────
  section "Step 1 of 2 — Listening Interface"
  _iface_select
  local iface="$_SELECTED_IFACE"
  local iface_ip="$_SELECTED_IFACE_IP"

  if [[ "$iface_ip" == "---" || -z "$iface_ip" ]]; then
    blank
    warn "Interface ${BOLD}${iface}${RESET}${YELLOW} has no IPv4 address."
    warn "ISC DHCP will refuse to start without an interface IP"
    warn "in the same subnet as at least one declared subnet."
    blank
    echo -e "  To assign a temporary address (adjust to your network):"
    echo -e "    ${DIM}sudo ip addr add 192.168.1.1/24 dev ${iface}${RESET}"
    echo -e "    ${DIM}sudo ip link set ${iface} up${RESET}"
    blank
    hint "For a permanent address edit /etc/network/interfaces or use NetworkManager."
    blank
    prompt_yn "Continue anyway?" N \
      || { info "Aborted. Re-run once the interface has an IP address."; return 1; }
  fi

  # ── Step 2: Subnets ────────────────────────────────────────────────────────
  section "Step 2 of 2 — Subnets"
  blank

  local -a subnets=()
  _collect_subnet _subnet_block
  subnets+=("$_subnet_block")

  while prompt_yn "Add another subnet?" N; do
    _collect_subnet _subnet_block
    subnets+=("$_subnet_block")
  done

  # ── Write config ───────────────────────────────────────────────────────────
  write_conf_header

  cat >> "$DHCPD_CONF" <<'EOF'
# — Global settings (edit via main menu → Global options) ——————————————————
authoritative;
log-facility local7;

option domain-name-servers 8.8.8.8, 8.8.4.4;

default-lease-time 86400;
max-lease-time 172800;

EOF

  for block in "${subnets[@]}"; do
    printf '%s\n\n' "$block" >> "$DHCPD_CONF"
  done

  _write_interface_file "$iface"

  blank
  if cmd_config_validate_quiet; then
    ok "Configuration is valid."
    blank
    prompt_yn "Enable and start the DHCP server now?" Y && {
      systemctl enable isc-dhcp-server
      systemctl restart isc-dhcp-server
      blank
      ok "DHCP server started on ${iface}."
      blank
      systemctl status isc-dhcp-server --no-pager -l | head -20
    }
  else
    err "Configuration has syntax errors. Please review:"
    cmd_config_validate
  fi
}

# ── Collect one subnet interactively ──────────────────────────────────────────
_collect_subnet() {
  local __out="$1"

  local cidr="" router="" range_start="" range_end=""
  local dns_override="" domain_override="" ntp="" wins=""
  local tftp="" boot_file="" lease_default="" lease_max=""
  local denied_unknown="allow"

  blank

  # Network (CIDR)
  while true; do
    prompt cidr "Subnet (CIDR)" "192.168.1.0/24"
    is_valid_cidr "$cidr" && break
    warn "Invalid CIDR. Example: 192.168.20.0/24"
  done

  local prefix="${cidr#*/}"
  local netmask; netmask=$(cidr_to_netmask "$prefix")
  local network; network=$(network_address "${cidr%/*}" "$netmask")
  local broadcast; broadcast=$(broadcast_address "${cidr%/*}" "$netmask")
  echo -e "  ${DIM}Network: ${network}   Netmask: ${netmask}   Broadcast: ${broadcast}${RESET}"
  blank

  # Dynamic pool
  if prompt_yn "Add a dynamic address pool (DHCP range)?" Y; then
    while true; do
      prompt range_start "  Pool start IP"
      is_valid_ip "$range_start" && break; warn "Invalid IP address."
    done
    while true; do
      prompt range_end "  Pool end IP"
      is_valid_ip "$range_end" && break; warn "Invalid IP address."
    done
  fi

  blank
  # Gateway
  while true; do
    prompt_opt router "Default gateway (optional, Enter to skip)"
    [[ -z "$router" ]] && break
    is_valid_ip "$router" && break; warn "Invalid IP address."
  done

  # DNS override
  prompt_opt dns_override "DNS servers for this subnet (optional, uses global if blank)"

  # Domain name
  prompt_opt domain_override "Domain name for this subnet (optional)"

  # NTP
  prompt_opt ntp "NTP server(s) (optional, space or comma separated)"

  # WINS
  prompt_opt wins "WINS server(s) (optional)"

  blank
  # Per-subnet lease times
  if prompt_yn "Set custom lease times for this subnet?" N; then
    while true; do
      prompt lease_default "  Default lease time (seconds)" "86400"
      is_valid_seconds "$lease_default" && break; warn "Must be a positive integer."
    done
    while true; do
      prompt lease_max "  Max lease time (seconds)" "172800"
      is_valid_seconds "$lease_max" && break; warn "Must be a positive integer."
    done
  fi

  # PXE boot
  if prompt_yn "Configure PXE boot for this subnet?" N; then
    while true; do
      prompt tftp "  TFTP server IP"
      is_valid_ip "$tftp" && break; warn "Invalid IP address."
    done
    prompt boot_file "  Boot filename" "pxelinux.0"
  fi

  # Deny unknown clients
  prompt_yn "Deny unknown (unregistered) clients on this subnet?" N \
    && denied_unknown="deny"

  # ── Build config block ─────────────────────────────────────────────────────
  local block
  block="# — Subnet ${network}/${prefix} ——————————————————————————————————————————
subnet ${network} netmask ${netmask} {"

  if [[ -n "$range_start" ]]; then
    block+="
  pool {
    ${denied_unknown} unknown clients;
    range ${range_start} ${range_end};"
    [[ -n "$lease_default" ]] && block+="
    default-lease-time ${lease_default};
    max-lease-time ${lease_max};"
    block+="
  }"
  fi

  [[ -n "$router" ]]          && block+="
  option routers ${router};"
  [[ -n "$dns_override" ]]    && block+="
  option domain-name-servers ${dns_override};"
  [[ -n "$domain_override" ]] && block+="
  option domain-name \"${domain_override}\";"
  [[ -n "$ntp" ]]             && block+="
  option ntp-servers ${ntp};"
  [[ -n "$wins" ]]            && block+="
  option netbios-name-servers ${wins};
  option netbios-node-type 8;"
  [[ -n "$tftp" ]]            && block+="
  next-server ${tftp};
  filename \"${boot_file}\";"

  block+="
}"

  printf -v "$__out" '%s' "$block"
}

# ── Interface selection ───────────────────────────────────────────────────────
_iface_select() {
  local -a ifaces=() macs=() ip4s=() states=()

  while IFS= read -r iface; do
    ifaces+=("$iface")
    macs+=("$(cat "/sys/class/net/${iface}/address" 2>/dev/null || echo "??:??:??:??:??:??")")
    local _ip; _ip=$(ip -4 addr show "$iface" 2>/dev/null | awk '/inet /{print $2}' | head -1)
    ip4s+=("${_ip:----}")
    local _st; _st=$(ip -o link show "$iface" 2>/dev/null | awk '{print $9}' | head -1)
    states+=("${_st:-UNKNOWN}")
  done < <(ip -o link show | awk -F': ' '{print $2}' | grep -v '^lo$')

  [[ ${#ifaces[@]} -eq 0 ]] && die "No network interfaces found."

  blank
  printf "  ${BOLD}%-4s %-16s %-20s %-20s %s${RESET}\n" \
    "#" "Interface" "MAC Address" "IPv4" "State"
  divider

  local i
  for (( i=0; i<${#ifaces[@]}; i++ )); do
    local _iface="${ifaces[$i]}" _mac="${macs[$i]}" _ip="${ip4s[$i]}" _st="${states[$i]}"
    local _stcol _active="" _ip_disp

    case "$_st" in
      UP)   _stcol="${GREEN}UP${RESET}    " ;;
      DOWN) _stcol="${RED}DOWN${RESET}  " ;;
      *)    _stcol="${YELLOW}${_st:0:6}${RESET}" ;;
    esac

    if [[ "$_ip" == "---" ]]; then
      _ip_disp="${YELLOW}─── (no IP)${RESET}"
    else
      _ip_disp="$_ip"
    fi

    [[ -f "$DHCPD_DEFAULT" ]] && grep -q "\"${_iface}\"" "$DHCPD_DEFAULT" 2>/dev/null \
      && _active=" ${CYAN}← dhcpd${RESET}"

    printf "  ${CYAN}%-4s${RESET}${BOLD}%-16s${RESET}${DIM}%-20s${RESET}" \
      "$((i+1)))" "$_iface" "$_mac"
    echo -e "$(printf "%-20s" "$_ip_disp")  ${_stcol}${_active}"
  done
  blank

  while true; do
    echo -ne "  ${BOLD}Select interface [1-${#ifaces[@]}]${RESET}: "
    read -r _sel
    if [[ "$_sel" =~ ^[0-9]+$ ]] && (( _sel >= 1 && _sel <= ${#ifaces[@]} )); then
      local _idx=$(( _sel - 1 ))
      _SELECTED_IFACE="${ifaces[$_idx]}"
      _SELECTED_IFACE_IP="${ip4s[$_idx]}"
      ok "Selected: ${BOLD}${_SELECTED_IFACE}${RESET}   IP: ${ip4s[$_idx]}   MAC: ${macs[$_idx]}"
      return 0
    fi
    warn "Enter a number between 1 and ${#ifaces[@]}."
  done
}

_write_interface_file() {
  local iface="$1"
  [[ -f "$DHCPD_DEFAULT" ]] && cp "$DHCPD_DEFAULT" "${DHCPD_DEFAULT}.bak"
  if grep -q 'INTERFACESv4' "$DHCPD_DEFAULT" 2>/dev/null; then
    sed -i "s/^INTERFACESv4=.*/INTERFACESv4=\"${iface}\"/" "$DHCPD_DEFAULT"
  else
    echo "INTERFACESv4=\"${iface}\"" >> "$DHCPD_DEFAULT"
  fi
  ok "Listening interface set to: ${BOLD}${iface}${RESET}"
}

# ── SUBNET commands ───────────────────────────────────────────────────────────
cmd_subnet_add() {
  require_root; require_dhcpd
  header "Add Subnet"
  backup_conf
  _collect_subnet _new_block
  printf '\n%s\n' "$_new_block" >> "$DHCPD_CONF"
  ok "Subnet added."
  cmd_config_validate_quiet \
    && { ok "Config valid."; _reload_prompt; } \
    || err "Config has errors — please fix manually."
}

cmd_subnet_list() {
  require_dhcpd
  header "Configured Subnets"
  local found=0
  printf "  ${BOLD}%-20s %-18s %s${RESET}\n" "Network" "Netmask" "Pool Range(s)"
  divider
  python3 - "$DHCPD_CONF" <<'PYEOF'
import sys, re
with open(sys.argv[1]) as f:
    content = f.read()
subnet_re = re.compile(r'subnet\s+([\d.]+)\s+netmask\s+([\d.]+)\s*\{(.*?)\n\}', re.DOTALL)
range_re  = re.compile(r'range\s+([\d.]+)\s+([\d.]+)')
found = False
for sm in subnet_re.finditer(content):
    net, mask, body = sm.group(1), sm.group(2), sm.group(3)
    ranges = [f"{m.group(1)} – {m.group(2)}" for m in range_re.finditer(body)]
    range_str = ', '.join(ranges) if ranges else '(no dynamic pool)'
    print(f"  {net:<20} {mask:<18} {range_str}")
    found = True
if not found:
    print("  No subnets configured.")
PYEOF
  [[ $found -eq 0 ]] || true
  _pause
}

cmd_subnet_remove() {
  require_root; require_dhcpd
  local target="${1:-}"
  [[ -z "$target" ]] && prompt target "Network address to remove (e.g. 192.168.20.0)"
  backup_conf
  python3 - "$DHCPD_CONF" "$target" <<'PYEOF'
import sys, re
conf_path, target = sys.argv[1], sys.argv[2]
with open(conf_path) as f:
    content = f.read()
# Try with comment header first
pat = r'#[^\n]*\n' + r'subnet\s+' + re.escape(target) + r'\s+netmask[^{]+\{[^}]*(?:\{[^}]*\}[^}]*)?\}'
new = re.sub(pat, '', content, flags=re.DOTALL)
if new == content:
    pat2 = r'subnet\s+' + re.escape(target) + r'\s+netmask[^{]+\{[^}]*(?:\{[^}]*\}[^}]*)?\}'
    new = re.sub(pat2, '', content, flags=re.DOTALL)
# Clean up excessive blank lines
new = re.sub(r'\n{3,}', '\n\n', new)
with open(conf_path, 'w') as f:
    f.write(new)
PYEOF
  ok "Subnet ${target} removed."
  cmd_config_validate_quiet \
    && { ok "Config valid."; _reload_prompt; } \
    || err "Config has errors after removal — please review."
}

# ── STATIC LEASES ─────────────────────────────────────────────────────────────
cmd_lease_static_add() {
  require_root; require_dhcpd
  header "Add Static Lease"

  local hostname="" mac="" ip="" extra_opts=""

  prompt hostname "Hostname"
  while true; do
    prompt mac "MAC address (xx:xx:xx:xx:xx:xx)"
    is_valid_mac "$mac" && break; warn "Invalid MAC — expected format: aa:bb:cc:dd:ee:ff"
  done
  while true; do
    prompt ip "Fixed IP address"
    is_valid_ip "$ip" && break; warn "Invalid IP address."
  done

  blank
  if prompt_yn "Add extra DHCP options for this host?" N; then
    hint "Leave option name blank when done."
    local _opt="" _val=""
    while true; do
      prompt_opt _opt "  Option name (e.g. routers, domain-name-servers)"
      [[ -z "$_opt" ]] && break
      prompt _val "  Value"
      extra_opts+="
  option ${_opt} ${_val};"
    done
  fi

  backup_conf
  cat >> "$DHCPD_CONF" <<EOF

# Static lease: ${hostname}
host ${hostname} {
  hardware ethernet ${mac};
  fixed-address ${ip};${extra_opts}
}
EOF
  ok "Static lease added: ${hostname}  ${mac} → ${ip}"
  cmd_config_validate_quiet \
    && { ok "Config valid."; _reload_prompt; } \
    || err "Config has errors — please review."
}

cmd_lease_static_list() {
  require_dhcpd
  header "Static Leases"
  printf "  ${BOLD}%-22s %-19s %s${RESET}\n" "Hostname" "MAC Address" "Fixed IP"
  divider
  python3 - "$DHCPD_CONF" <<'PYEOF'
import sys, re
with open(sys.argv[1]) as f:
    content = f.read()
host_re = re.compile(r'^host\s+(\S+)\s*\{(.*?)\n\}', re.DOTALL | re.MULTILINE)
mac_re  = re.compile(r'hardware ethernet\s+([\w:]+)\s*;')
ip_re   = re.compile(r'fixed-address\s+([\d.]+)\s*;')
found = False
for m in host_re.finditer(content):
    hostname, body = m.group(1), m.group(2)
    mac_m = mac_re.search(body)
    ip_m  = ip_re.search(body)
    mac = mac_m.group(1) if mac_m else '—'
    ip  = ip_m.group(1)  if ip_m  else '—'
    print(f"  {hostname:<22} {mac:<19} {ip}")
    found = True
if not found:
    print("  No static leases configured.")
PYEOF
  _pause
}

cmd_lease_static_remove() {
  require_root; require_dhcpd
  local mac="${1:-}"
  [[ -z "$mac" ]] && prompt mac "MAC address of lease to remove"
  backup_conf
  python3 - "$DHCPD_CONF" "$mac" <<'PYEOF'
import sys, re
conf_path, mac = sys.argv[1], sys.argv[2].lower()
with open(conf_path) as f:
    content = f.read()
pat = r'(?:#[^\n]*\n)?host\s+\S+\s*\{[^}]*hardware\s+ethernet\s+' + re.escape(mac) + r'[^}]*\}'
new = re.sub(pat, '', content, flags=re.DOTALL|re.IGNORECASE)
new = re.sub(r'\n{3,}', '\n\n', new)
with open(conf_path, 'w') as f:
    f.write(new)
PYEOF
  ok "Static lease for ${mac} removed."
  cmd_config_validate_quiet \
    && { ok "Config valid."; _reload_prompt; } \
    || err "Config has errors — please review."
}

# ── ACTIVE LEASES ─────────────────────────────────────────────────────────────
cmd_lease_list() {
  header "Active Leases"
  if [[ ! -f "$LEASES_FILE" ]]; then
    info "Leases file not found: ${LEASES_FILE}"
    hint "The server may not have issued any leases yet."
    _pause; return 0
  fi
  printf "  ${BOLD}%-18s %-19s %-22s %-22s %s${RESET}\n" \
    "IP Address" "MAC Address" "Hostname" "Starts" "Ends"
  divider
  python3 - "$LEASES_FILE" <<'PYEOF'
import sys, re
LEASE_RE = re.compile(r'lease\s+([\d.]+)\s*\{(.*?)\}', re.DOTALL)
F = {
    'mac':   re.compile(r'hardware ethernet\s+([\w:]+);'),
    'host':  re.compile(r'client-hostname\s+"([^"]+)"'),
    'start': re.compile(r'starts\s+\d+\s+([\d/ :]+);'),
    'end':   re.compile(r'ends\s+\d+\s+([\d/ :]+);'),
    'bind':  re.compile(r'binding state\s+(\w+);'),
}
with open(sys.argv[1]) as f:
    content = f.read()
leases = {}
for m in LEASE_RE.finditer(content):
    ip, body = m.group(1), m.group(2)
    rec = {'ip': ip}
    for k, rx in F.items():
        mo = rx.search(body)
        rec[k] = mo.group(1) if mo else ''
    if rec.get('bind') == 'active':
        leases[ip] = rec
if not leases:
    print("  No active leases found.")
else:
    print(f"  {'(total: ' + str(len(leases)) + ' active)'}")
    print()
    for ip, r in sorted(leases.items()):
        print(f"  {r['ip']:<18} {r['mac']:<19} {r.get('host',''):<22} {r['start']:<22} {r['end']}")
PYEOF
  _pause
}

# ── GLOBAL OPTIONS ────────────────────────────────────────────────────────────
cmd_option_set() {
  require_root; require_dhcpd
  header "Set Global DHCP Options"
  hint "These apply server-wide unless overridden per-subnet."
  blank

  local _choice=""
  prompt_select _choice "Which option?" \
    "DNS servers" \
    "Domain name" \
    "Default lease time" \
    "Maximum lease time" \
    "Authoritative" \
    "Log facility" \
    "Custom (enter manually)"

  local opt_name="" opt_value=""

  case "$_choice" in
    "DNS servers")
      opt_name="option domain-name-servers"
      prompt opt_value "DNS server(s)" "8.8.8.8, 8.8.4.4"
      ;;
    "Domain name")
      prompt_opt opt_value "Domain name (blank to remove from config)"
      backup_conf
      if [[ -z "$opt_value" ]]; then
        sed -i '/^option domain-name "/d' "$DHCPD_CONF"
        ok "option domain-name removed."
      elif grep -q '^option domain-name "' "$DHCPD_CONF"; then
        sed -i "s|^option domain-name \".*\"|option domain-name \"${opt_value}\";|" "$DHCPD_CONF"
        ok "Updated: option domain-name \"${opt_value}\";"
      else
        sed -i "0,/^authoritative/s/^authoritative/option domain-name \"${opt_value}\";\nauthoritative/" \
          "$DHCPD_CONF"
        ok "Added: option domain-name \"${opt_value}\";"
      fi
      cmd_config_validate_quiet && ok "Config valid." && _reload_prompt
      return 0
      ;;
    "Default lease time")
      opt_name="default-lease-time"
      while true; do
        prompt opt_value "Default lease time (seconds)" "86400"
        is_valid_seconds "$opt_value" && break; warn "Must be a positive integer."
      done
      ;;
    "Maximum lease time")
      opt_name="max-lease-time"
      while true; do
        prompt opt_value "Maximum lease time (seconds)" "172800"
        is_valid_seconds "$opt_value" && break; warn "Must be a positive integer."
      done
      ;;
    "Authoritative")
      local _auth=""
      prompt_select _auth "Authoritative setting:" "authoritative" "not authoritative"
      backup_conf
      sed -i 's/^\(not \)\?authoritative;.*/'"${_auth}"';/' "$DHCPD_CONF"
      ok "Set: ${_auth};"
      cmd_config_validate_quiet && ok "Config valid." && _reload_prompt
      return 0
      ;;
    "Log facility")
      opt_name="log-facility"
      prompt opt_value "Log facility" "local7"
      ;;
    "Custom"*)
      prompt opt_name  "Option name  (e.g. option ntp-servers)"
      prompt opt_value "Option value"
      ;;
  esac

  [[ -z "$opt_name" ]] && return 0

  backup_conf
  if grep -qE "^${opt_name}[[:space:];]" "$DHCPD_CONF" 2>/dev/null; then
    sed -i "s|^${opt_name}.*|${opt_name} ${opt_value};|" "$DHCPD_CONF"
    ok "Updated: ${opt_name} ${opt_value};"
  else
    sed -i "0,/^authoritative/s/^authoritative/${opt_name} ${opt_value};\nauthoritative/" \
      "$DHCPD_CONF"
    ok "Added: ${opt_name} ${opt_value};"
  fi
  cmd_config_validate_quiet && ok "Config valid." && _reload_prompt
}

cmd_option_list() {
  require_dhcpd
  header "Global DHCP Options"
  local found=0
  printf "  ${BOLD}%-40s %s${RESET}\n" "Option" "Value"
  divider
  while IFS= read -r line; do
    # Strip trailing semicolon for display
    local display="${line%;}"
    echo -e "  ${GREEN}▸${RESET} ${display}"
    found=1
  done < <(grep -E \
    '^(option |default-lease-time|max-lease-time|authoritative|not authoritative|log-facility)' \
    "$DHCPD_CONF" 2>/dev/null || true)
  [[ $found -eq 0 ]] && info "No global options found in config."
  _pause
}

# ── INTERFACE ─────────────────────────────────────────────────────────────────
cmd_interface_set() {
  require_root
  local iface="${1:-}"
  if [[ -z "$iface" ]]; then
    _iface_select; iface="$_SELECTED_IFACE"
  fi
  _write_interface_file "$iface"
  _reload_prompt
}

cmd_interface_list() {
  header "Network Interfaces"
  printf "  ${BOLD}%-16s %-20s %-18s %-9s %s${RESET}\n" \
    "Interface" "MAC Address" "IPv4 Address" "State" "DHCP"
  divider
  while IFS= read -r iface; do
    local mac; mac=$(cat "/sys/class/net/${iface}/address" 2>/dev/null || echo "??:??:??:??:??:??")
    local ip4; ip4=$(ip -4 addr show "$iface" 2>/dev/null | awk '/inet /{print $2}' | head -1)
    ip4="${ip4:----}"
    local state; state=$(ip link show "$iface" 2>/dev/null | awk '/state/{print $9}' | head -1)
    state="${state:-UNKNOWN}"
    local ststr
    case "$state" in
      UP)   ststr="${GREEN}UP${RESET}      " ;;
      DOWN) ststr="${RED}DOWN${RESET}    " ;;
      *)    ststr="${YELLOW}${state:0:8}${RESET}" ;;
    esac
    local listener=""
    [[ -f "$DHCPD_DEFAULT" ]] && grep -q "\"${iface}\"" "$DHCPD_DEFAULT" 2>/dev/null \
      && listener="${CYAN}← dhcpd${RESET}"
    printf "  ${BOLD}%-16s${RESET}${DIM}%-20s${RESET}%-18s" "$iface" "$mac" "$ip4"
    echo -e "  ${ststr}  ${listener}"
  done < <(ip -o link show | awk -F': ' '{print $2}' | grep -v '^lo$')
  blank
  _pause
}

# ── PXE BOOT ──────────────────────────────────────────────────────────────────
cmd_pxe_configure() {
  require_root; require_dhcpd
  header "PXE Boot Configuration"
  local tftp_server="" boot_file="" target_subnet=""

  while true; do
    prompt tftp_server "TFTP server IP address"
    is_valid_ip "$tftp_server" && break; warn "Invalid IP address."
  done
  prompt boot_file "Boot filename" "pxelinux.0"
  prompt target_subnet "Apply to subnet (network address) or 'global'" "global"

  backup_conf
  if [[ "$target_subnet" == "global" ]]; then
    printf '\n# — PXE Boot (global) ————————————————————————————————————\nnext-server %s;\nfilename "%s";\n' \
      "$tftp_server" "$boot_file" >> "$DHCPD_CONF"
    ok "PXE boot options added globally."
  else
    python3 - "$DHCPD_CONF" "${target_subnet%/*}" "$tftp_server" "$boot_file" <<'PYEOF'
import sys, re
conf, net, tftp, bfile = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
with open(conf) as f: content = f.read()
insert = f'\n  next-server {tftp};\n  filename "{bfile}";'
new = re.sub(r'(subnet\s+' + re.escape(net) + r'[^{]*\{)', r'\1' + insert, content)
with open(conf, 'w') as f: f.write(new)
PYEOF
    ok "PXE boot options added to subnet ${target_subnet}."
  fi
  cmd_config_validate_quiet && ok "Config valid." && _reload_prompt
}

# ── FAILOVER ──────────────────────────────────────────────────────────────────
cmd_failover_configure() {
  require_root; require_dhcpd
  header "DHCP Failover Configuration"
  info "Failover pairs two DHCP servers. Configure primary first, then secondary."
  blank

  local role="" peer_name="" my_ip="" peer_ip="" mclt="3600" split="128"
  prompt_select role "This server's role:" "primary" "secondary"
  prompt peer_name "Failover peer name (must match on both servers)" "dhcp-failover"
  while true; do prompt my_ip   "This server's IP"; is_valid_ip "$my_ip"  && break; warn "Invalid IP."; done
  while true; do prompt peer_ip "Peer server's IP";  is_valid_ip "$peer_ip" && break; warn "Invalid IP."; done

  if [[ "$role" == "primary" ]]; then
    prompt mclt  "MCLT — max client lead time (seconds)" "3600"
    prompt split "Split value (0-256, 128 = 50/50)"     "128"
  fi

  local fb
  if [[ "$role" == "primary" ]]; then
    fb="failover peer \"${peer_name}\" {
  primary;
  address ${my_ip};
  port 647;
  peer address ${peer_ip};
  peer port 647;
  max-response-delay 30;
  max-unacked-updates 10;
  mclt ${mclt};
  split ${split};
  load balance max seconds 3;
}"
  else
    fb="failover peer \"${peer_name}\" {
  secondary;
  address ${my_ip};
  port 647;
  peer address ${peer_ip};
  peer port 647;
  max-response-delay 30;
  max-unacked-updates 10;
  load balance max seconds 3;
}"
  fi

  backup_conf
  printf '\n# — Failover ————————————————————————————————————————————\n%s\n' \
    "$fb" >> "$DHCPD_CONF"

  blank
  info "Add  failover peer \"${peer_name}\";  inside each pool that should use failover."
  ok "Failover block written."
  cmd_config_validate_quiet || err "Config has errors — please review."
}

# ── POOL management ───────────────────────────────────────────────────────────
cmd_pool_add() {
  require_root; require_dhcpd
  header "Add Address Pool to Subnet"
  local target_net="" range_start="" range_end=""
  prompt target_net "Subnet network address (e.g. 192.168.20.0)"
  while true; do prompt range_start "Pool start IP"; is_valid_ip "$range_start" && break; warn "Invalid IP."; done
  while true; do prompt range_end   "Pool end IP";   is_valid_ip "$range_end"   && break; warn "Invalid IP."; done

  local allow_deny="allow"
  prompt_yn "Deny unknown clients in this pool?" N && allow_deny="deny"

  local lease_d="" lease_m=""
  if prompt_yn "Set pool-specific lease times?" N; then
    while true; do prompt lease_d "Default lease (seconds)" "86400";  is_valid_seconds "$lease_d" && break; warn "Must be a positive integer."; done
    while true; do prompt lease_m "Max lease (seconds)"     "172800"; is_valid_seconds "$lease_m" && break; warn "Must be a positive integer."; done
  fi

  backup_conf
  local pool_block
  pool_block="  pool {\n    ${allow_deny} unknown clients;\n    range ${range_start} ${range_end};"
  [[ -n "$lease_d" ]] && pool_block+="\n    default-lease-time ${lease_d};\n    max-lease-time ${lease_m};"
  pool_block+="\n  }"

  python3 - "$DHCPD_CONF" "$target_net" "$pool_block" <<'PYEOF'
import sys, re
conf, net, pool = sys.argv[1], sys.argv[2], sys.argv[3]
with open(conf) as f: content = f.read()
new = re.sub(r'(subnet\s+' + re.escape(net) + r'[^{]*\{)', r'\1\n' + pool, content)
with open(conf, 'w') as f: f.write(new)
PYEOF
  ok "Pool ${range_start} – ${range_end} added to subnet ${target_net}."
  cmd_config_validate_quiet && ok "Config valid." && _reload_prompt
}

cmd_pool_list() {
  require_dhcpd
  header "Address Pools"
  printf "  ${BOLD}%-30s %s${RESET}\n" "Subnet" "Pool Range"
  divider
  python3 - "$DHCPD_CONF" <<'PYEOF'
import sys, re
with open(sys.argv[1]) as f: content = f.read()
subnet_re = re.compile(r'subnet\s+([\d.]+)\s+netmask\s+([\d.]+)\s*\{(.*?)\n\}', re.DOTALL)
pool_re   = re.compile(r'pool\s*\{(.*?)\}', re.DOTALL)
range_re  = re.compile(r'range\s+([\d.]+)\s+([\d.]+)')
found = False
for sm in subnet_re.finditer(content):
    net, mask, body = sm.group(1), sm.group(2), sm.group(3)
    for pm in pool_re.finditer(body):
        rm = range_re.search(pm.group(1))
        if rm:
            label = f"{net}/{mask}"
            print(f"  {label:<30} {rm.group(1)} – {rm.group(2)}")
            found = True
if not found:
    print("  No address pools configured.")
PYEOF
  _pause
}

