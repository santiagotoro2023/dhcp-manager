# ── UNINSTALL ─────────────────────────────────────────────────────────────────
cmd_uninstall() {
  require_root
  header "Uninstall & Clean ISC DHCP Server"

  echo -e "${YELLOW}This will perform a full system clean:${RESET}"
  echo -e "  ${DIM}•${RESET} Stop and disable isc-dhcp-server service"
  echo -e "  ${DIM}•${RESET} Purge isc-dhcp-server package (apt --purge)"
  echo -e "  ${DIM}•${RESET} Remove /etc/dhcp/dhcpd.conf"
  echo -e "  ${DIM}•${RESET} Remove /etc/default/isc-dhcp-server"
  echo -e "  ${DIM}•${RESET} Remove /var/lib/dhcp/dhcpd.leases*"
  echo -e "  ${DIM}•${RESET} Remove any leftover /etc/dhcp/ package files"
  echo -e "  ${DIM}•${RESET} Run apt autoremove"
  echo ""

  local keep_backups=true
  if [[ -d "$BACKUP_DIR" ]] && [[ -n "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]]; then
    echo -e "  ${CYAN}Backups found in:${RESET} ${BACKUP_DIR}/"
    ls -1t "$BACKUP_DIR" | while read -r b; do echo -e "    ${DIM}${b}${RESET}"; done
    echo ""
    prompt_yn "  Delete config backups too? (say N to keep them)" N       && keep_backups=false || keep_backups=true
  fi

  echo ""
  prompt_yn "Proceed with full uninstall?" N || { info "Aborted. Nothing was changed."; return 0; }

  # ── 1. Backup before we nuke (only if keeping) ──────────────────────────────
  if $keep_backups; then
    backup_conf
    ok "Final config backup saved to ${BACKUP_DIR}/"
  fi

  # ── 2. Stop & disable service ────────────────────────────────────────────────
  info "Stopping and disabling isc-dhcp-server..."
  systemctl stop    isc-dhcp-server 2>/dev/null && ok "Service stopped."   || warn "Service was not running."
  systemctl disable isc-dhcp-server 2>/dev/null && ok "Service disabled."  || warn "Service was not enabled."

  # ── 3. Purge package ────────────────────────────────────────────────────────
  info "Purging isc-dhcp-server package..."
  if dpkg -l isc-dhcp-server &>/dev/null; then
    DEBIAN_FRONTEND=noninteractive apt-get remove --purge -y isc-dhcp-server 2>&1 | grep -v "^$" || true
    ok "Package purged."
  else
    info "Package was not installed via apt — skipping."
  fi

  # ── 4. Remove config files left behind ─────────────────────────────────────
  info "Removing residual configuration files..."

  local removed=0

  _rm_if_exists() {
    local f="$1"
    if [[ -e "$f" ]]; then
      rm -f "$f" && info "  Removed: ${f}" && ((removed++))
    fi
  }

  _rm_if_exists "$DHCPD_CONF"
  _rm_if_exists "${DHCPD_CONF}.bak"
  _rm_if_exists "$DHCPD_DEFAULT"
  _rm_if_exists "${DHCPD_DEFAULT}.bak"
  _rm_if_exists "$LEASES_FILE"
  _rm_if_exists "${LEASES_FILE}~"

  # Extra lease files
  for f in /var/lib/dhcp/dhcpd.leases.*; do
    [[ -e "$f" ]] && rm -f "$f" && info "  Removed: ${f}" && ((removed++)) || true
  done

  # Remove /etc/dhcp/ only if empty after backup decision
  if $keep_backups; then
    # Remove everything except backups dir
    find /etc/dhcp/ -maxdepth 1 -not -name "backups" -not -path "/etc/dhcp/"       -exec rm -rf {} + 2>/dev/null && info "  Cleaned /etc/dhcp/ (backups preserved)" || true
  else
    rm -rf /etc/dhcp/ && info "  Removed: /etc/dhcp/ (including backups)" && ((removed++)) || true
  fi

  # Systemd unit drop-ins if any
  if [[ -d /etc/systemd/system/isc-dhcp-server.service.d ]]; then
    rm -rf /etc/systemd/system/isc-dhcp-server.service.d
    info "  Removed: systemd drop-in directory"
    systemctl daemon-reload
  fi

  # ── 5. Autoremove orphaned dependencies ────────────────────────────────────
  info "Running apt autoremove..."
  DEBIAN_FRONTEND=noninteractive apt-get autoremove -y 2>&1 | grep -v "^$" || true

  # ── 6. Final verification ───────────────────────────────────────────────────
  echo ""
  divider
  echo -e "${BOLD}Clean-up summary:${RESET}"

  if command -v dhcpd &>/dev/null; then
    warn "dhcpd binary still found at: $(command -v dhcpd)"
    warn "You may need to remove it manually or check for manual installations."
  else
    ok "dhcpd binary: not present"
  fi

  if dpkg -l isc-dhcp-server &>/dev/null 2>&1 | grep -q "^ii"; then
    warn "Package still appears installed — check: dpkg -l isc-dhcp-server"
  else
    ok "Package: fully removed"
  fi

  [[ -f "$DHCPD_CONF" ]]    && warn "Config still present: ${DHCPD_CONF}" || ok "Config files: removed"
  [[ -f "$LEASES_FILE" ]]   && warn "Leases file still present: ${LEASES_FILE}" || ok "Lease files: removed"

  if $keep_backups && [[ -d "$BACKUP_DIR" ]]; then
    info "Backups preserved at: ${BACKUP_DIR}/"
    info "To remove them manually: sudo rm -rf ${BACKUP_DIR}"
  fi

  echo ""
  ok "isc-dhcp-server has been fully removed. System is clean."

  # Suggest reinstall path
  echo -e "
${DIM}To reinstall: sudo dhcp-manager install${RESET}"
}

# ── Reload helper ─────────────────────────────────────────────────────────────
