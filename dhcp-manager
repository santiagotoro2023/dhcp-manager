}

cmd_config_backup() {
  require_root
  require_dhcpd
  backup_conf
  ok "Backup complete → ${BACKUP_DIR}/"
  ls -lt "$BACKUP_DIR" | head -6
}

cmd_config_restore() {
  require_root
  require_dhcpd
  header "Restore Configuration from Backup"
  if [[ ! -d "$BACKUP_DIR" ]] || [[ -z "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]]; then
    die "No backups found in ${BACKUP_DIR}/"
  fi
  local -a backups=()
  while IFS= read -r f; do
    backups+=("$(basename "$f")")
  done < <(ls -1t "${BACKUP_DIR}"/dhcpd.conf.* 2>/dev/null)
  prompt_select _backup_choice "Select backup to restore:" "${backups[@]}"
  cp "${BACKUP_DIR}/${_backup_choice}" "$DHCPD_CONF"
  ok "Restored from ${_backup_choice}."
  cmd_config_validate_quiet && ok "Config valid." && _reload_prompt
}

