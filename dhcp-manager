  sudo chmod +x /usr/local/bin/dhcp-manager
HELP
}

# ── INTERACTIVE MAIN MENU ─────────────────────────────────────────────────────
cmd_interactive() {
  while true; do
    # ── Status bar ────────────────────────────────────────────────────────────
    local _state; _state=$(_service_state)
    local _iface; _iface=$(_active_interface)
    local _subnets; _subnets=$(_subnet_count)
    local _leases; _leases=$(_active_lease_count)

    local _state_col
    case "$_state" in
      running)       _state_col="${GREEN}${_state}${RESET}" ;;
      failed)        _state_col="${RED}${_state}${RESET}" ;;
      "not installed") _state_col="${YELLOW}${_state}${RESET}" ;;
      *)             _state_col="${DIM}${_state}${RESET}" ;;
    esac

    clear 2>/dev/null || true
    echo -e "${BOLD}${CYAN}"
    echo -e "  ╔══════════════════════════════════════╗"
    echo -e "  ║        dhcp-manager  v${VERSION}         ║"
    echo -e "  ╚══════════════════════════════════════╝${RESET}"
    blank
    echo -e "  ${DIM}Service:${RESET}   ${_state_col}    ${DIM}Interface:${RESET} ${BOLD}${_iface}${RESET}"
    echo -e "  ${DIM}Subnets:${RESET}   ${BOLD}${_subnets}${RESET}           ${DIM}Leases:${RESET}    ${BOLD}${_leases}${RESET} active"
    blank
    divider
    echo -e "  ${CYAN} 1${RESET}  Install DHCP server"
    echo -e "  ${CYAN} 2${RESET}  Configuration wizard"
    echo -e "  ${CYAN} 3${RESET}  Manage subnets"
    echo -e "  ${CYAN} 4${RESET}  Manage leases"
    echo -e "  ${CYAN} 5${RESET}  Global options"
    echo -e "  ${CYAN} 6${RESET}  Network interface"
    echo -e "  ${CYAN} 7${RESET}  Service control"
    echo -e "  ${CYAN} 8${RESET}  Configuration file"
    echo -e "  ${CYAN} 9${RESET}  PXE boot"
    echo -e "  ${CYAN}10${RESET}  Failover"
    echo -e "  ${CYAN}11${RESET}  Address pools"
    echo -e "  ${CYAN}12${RESET}  View logs"
    echo -e "  ${CYAN}13${RESET}  Uninstall"
    echo -e "  ${CYAN} 0${RESET}  Exit"
    divider
    blank
    echo -ne "  ${BOLD}Choice${RESET}: "
    read -r _choice
    case "$_choice" in
      1)  cmd_install ;;
      2)  cmd_configure ;;
      3)  _menu_subnet ;;
      4)  _menu_lease ;;
      5)  _menu_option ;;
      6)  _menu_interface ;;
      7)  _menu_service ;;
      8)  _menu_config ;;
      9)  cmd_pxe_configure ;;
      10) cmd_failover_configure ;;
      11) _menu_pool ;;
      12) cmd_log_show ;;
      13) cmd_uninstall ;;
      0)  blank; echo -e "  ${DIM}Goodbye.${RESET}"; blank; exit 0 ;;
      "")  ;;  # ignore accidental Enter
      *)  warn "Invalid choice '${_choice}' — enter a number from the menu." ;;
    esac
  done
}

# ── Sub-menus ─────────────────────────────────────────────────────────────────
_menu_subnet() {
  local _s=""
  prompt_select _s "Subnet Management:" \
    "Add subnet" "List subnets" "Remove subnet" "← Back"
  case "$_s" in
    "Add subnet")    cmd_subnet_add ;;
    "List subnets")  cmd_subnet_list ;;
    "Remove subnet") cmd_subnet_remove ;;
  esac
}

_menu_lease() {
  local _s=""
  prompt_select _s "Lease Management:" \
    "List active leases" "Add static lease" "List static leases" "Remove static lease" "← Back"
  case "$_s" in
    "List active leases")  cmd_lease_list ;;
    "Add static lease")    cmd_lease_static_add ;;
    "List static leases")  cmd_lease_static_list ;;
    "Remove static lease") cmd_lease_static_remove ;;
  esac
}

_menu_option() {
  local _s=""
  prompt_select _s "Global Options:" "Set option" "List options" "← Back"
  case "$_s" in
    "Set option")   cmd_option_set ;;
    "List options") cmd_option_list ;;
  esac
}

_menu_interface() {
  local _s=""
  prompt_select _s "Interface:" "Set interface" "List interfaces" "← Back"
  case "$_s" in
    "Set interface")   cmd_interface_set ;;
    "List interfaces") cmd_interface_list ;;
  esac
}

_menu_service() {
  local _s=""
  prompt_select _s "Service Control:" \
    "Status" "Start" "Stop" "Restart" "Reload" "Enable" "Disable" "← Back"
  [[ "$_s" == "← Back" ]] && return
  blank
  cmd_service "${_s,,}"
  _pause
}

_menu_config() {
  local _s=""
  prompt_select _s "Configuration File:" \
    "Show config" "Edit config" "Validate config" "Backup config" "Restore config" "← Back"
  case "$_s" in
    "Show config")     cmd_config_show ;;
    "Edit config")     cmd_config_edit ;;
    "Validate config") cmd_config_validate ;;
    "Backup config")   cmd_config_backup ;;
    "Restore config")  cmd_config_restore ;;
  esac
}

_menu_pool() {
  local _s=""
  prompt_select _s "Address Pools:" "Add pool" "List pools" "← Back"
  case "$_s" in
    "Add pool")   cmd_pool_add ;;
    "List pools") cmd_pool_list ;;
  esac
}

# ── ENTRY POINT ───────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-}"
  case "$cmd" in
    install)   cmd_install ;;
    configure) cmd_configure ;;
    uninstall) cmd_uninstall ;;

    subnet)
      case "${2:-list}" in
        add)    cmd_subnet_add ;;
        list)   cmd_subnet_list ;;
        remove) cmd_subnet_remove "${3:-}" ;;
        *)      die "Unknown subnet subcommand: '${2}'" ;;
      esac ;;

    lease)
      case "${2:-list}" in
        list) cmd_lease_list ;;
        static)
          case "${3:-list}" in
            add)    cmd_lease_static_add ;;
            list)   cmd_lease_static_list ;;
            remove) cmd_lease_static_remove "${4:-}" ;;
            *)      die "Unknown lease static subcommand: '${3}'" ;;
          esac ;;
        *) die "Unknown lease subcommand: '${2}'" ;;
      esac ;;

    option)
      case "${2:-list}" in
        set)  cmd_option_set ;;
        list) cmd_option_list ;;
        *)    die "Unknown option subcommand: '${2}'" ;;
      esac ;;

    interface)
      case "${2:-list}" in
        set)  cmd_interface_set "${3:-}" ;;
        list) cmd_interface_list ;;
        *)    die "Unknown interface subcommand: '${2}'" ;;
      esac ;;

    service) cmd_service "${2:-status}" ;;

    config)
      case "${2:-show}" in
        show)     cmd_config_show ;;
        edit)     cmd_config_edit ;;
        validate) cmd_config_validate ;;
        backup)   cmd_config_backup ;;
        restore)  cmd_config_restore ;;
        *)        die "Unknown config subcommand: '${2}'" ;;
      esac ;;

    pxe)
      [[ "${2:-configure}" == "configure" ]] && cmd_pxe_configure \
        || die "Unknown pxe subcommand: '${2}'" ;;

    failover)
      [[ "${2:-configure}" == "configure" ]] && cmd_failover_configure \
        || die "Unknown failover subcommand: '${2}'" ;;

    pool)
      case "${2:-list}" in
        add)  cmd_pool_add ;;
        list) cmd_pool_list ;;
        *)    die "Unknown pool subcommand: '${2}'" ;;
      esac ;;

    log)
      [[ "${2:-show}" == "show" ]] && cmd_log_show \
        || die "Unknown log subcommand: '${2}'" ;;

    --help|-h|help)        cmd_help ;;
    --version|-v|version)  echo "dhcp-manager v${VERSION}" ;;
    "")                    cmd_interactive ;;
    *)
      err "Unknown command: '${cmd}'"
      blank
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
