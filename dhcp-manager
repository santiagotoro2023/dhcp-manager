# ── UNINSTALL ─────────────────────────────────────────────────────────────────
_rm_file() { [[ -e "$1" ]] && rm -f "$1" && info "  Removed: $1" || true; }

cmd_uninstall() {
  require_root
  header "Uninstall ISC DHCP Server"

  local self_path; self_path=$(readlink -f "${BASH_SOURCE[0]}")

  echo -e "${YELLOW}This will:${RESET}"
  echo -e "  ${DIM}•${RESET} Stop and disable isc-dhcp-server"
  echo -e "  ${DIM}•${RESET} Purge the isc-dhcp-server package"
  echo -e "  ${DIM}•${RESET} Remove config, leases, and interface files"
  echo -e "  ${DIM}•${RESET} Run apt autoremove"
  blank

  local keep_backups=true remove_self=false

  if [[ -d "$BACKUP_DIR" ]] && [[ -n "$(ls -A "$BACKUP_DIR" 2>/dev/null)" ]]; then
    echo -e "  ${CYAN}Backups found:${RESET} ${BACKUP_DIR}/"
    prompt_yn "  Delete backups too?" N && keep_backups=false
  fi

  echo -e "  ${DIM}Utility is installed at: ${self_path}${RESET}"
  prompt_yn "  Remove the dhcp-manager utility itself?" N && remove_self=true

  blank
  prompt_yn "Proceed with full uninstall?" N \
    || { info "Aborted. Nothing was changed."; return 0; }

  # ── Cleanup (best-effort: individual failures must not abort the block) ────
  set +e

  $keep_backups && backup_conf

  info "Stopping and disabling service..."
  systemctl stop    isc-dhcp-server 2>/dev/null
  systemctl disable isc-dhcp-server 2>/dev/null

  info "Purging package..."
  if dpkg-query -W -f='${Status}' isc-dhcp-server 2>/dev/null | grep -q "install ok"; then
    DEBIAN_FRONTEND=noninteractive apt-get remove --purge -y isc-dhcp-server 2>/dev/null
    ok "Package purged."
  else
    info "Package not found — skipping."
  fi

  info "Removing config and runtime files..."
  _rm_file "$DHCPD_CONF"
  _rm_file "${DHCPD_CONF}.bak"
  _rm_file "$DHCPD_DEFAULT"
  _rm_file "${DHCPD_DEFAULT}.bak"
  _rm_file "$LEASES_FILE"
  _rm_file "${LEASES_FILE}~"
  for f in /var/lib/dhcp/dhcpd.leases.*; do _rm_file "$f"; done

  if $keep_backups; then
    find /etc/dhcp/ -maxdepth 1 ! -name "backups" ! -path "/etc/dhcp/" \
      -exec rm -rf {} + 2>/dev/null
    info "  Cleaned /etc/dhcp/ (backups preserved)"
  else
    rm -rf /etc/dhcp/ 2>/dev/null
    info "  Removed /etc/dhcp/"
  fi

  if [[ -d /etc/systemd/system/isc-dhcp-server.service.d ]]; then
    rm -rf /etc/systemd/system/isc-dhcp-server.service.d
    systemctl daemon-reload 2>/dev/null
    info "  Removed systemd drop-in directory"
  fi

  info "Running apt autoremove..."
  DEBIAN_FRONTEND=noninteractive apt-get autoremove -y 2>/dev/null

  if $remove_self; then
    info "Removing dhcp-manager utility..."
    for loc in "$self_path" \
               /usr/local/bin/dhcp-manager \
               /usr/bin/dhcp-manager \
               /opt/dhcp-manager/dhcp-manager; do
      [[ -f "$loc" ]] && rm -f "$loc" && ok "  Removed: ${loc}"
    done
  fi

  set -euo pipefail

  # ── Verification summary ──────────────────────────────────────────────────
  blank; divider
  echo -e "${BOLD}Verification:${RESET}"
  command -v dhcpd &>/dev/null \
    && warn "dhcpd binary still present: $(command -v dhcpd)" \
    || ok "dhcpd binary:     not present"
  dpkg-query -W -f='${Status}' isc-dhcp-server 2>/dev/null | grep -q "install ok" \
    && warn "Package still installed — run: sudo apt purge isc-dhcp-server" \
    || ok "Package:          fully removed"
  [[ -f "$DHCPD_CONF" ]]  && warn "Config still present:  ${DHCPD_CONF}"  || ok "Config files:     removed"
  [[ -f "$LEASES_FILE" ]] && warn "Leases still present:  ${LEASES_FILE}" || ok "Lease files:      removed"
  if $remove_self; then
    [[ -f "$self_path" ]] \
      && warn "Utility still present: ${self_path}" \
      || ok "dhcp-manager:     removed"
  fi
  $keep_backups && [[ -d "$BACKUP_DIR" ]] && \
    info "Backups preserved: ${BACKUP_DIR}/  (to remove: sudo rm -rf ${BACKUP_DIR})"
  blank
  ok "Uninstall complete."
}

# ── Reload helper ─────────────────────────────────────────────────────────────
_reload_prompt() {
  systemctl is-active --quiet isc-dhcp-server 2>/dev/null || return 0
  blank
  prompt_yn "Reload DHCP server to apply changes?" Y && {
    systemctl reload-or-restart isc-dhcp-server
    ok "DHCP server reloaded."
  }
}

